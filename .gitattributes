# Line ending normalization — repo-driven, independent of core.autocrlf.
# All auto-detected text files: store LF in the repo and check out as LF.
* text=auto eol=lf

# Source and scripting files — explicit LF
*.lua   text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.xml   text eol=lf

# Dot-files
.gitattributes  text eol=lf
.gitignore      text eol=lf

# Binary — do not normalize
*.zip   binary
*.png   binary
*.jpg   binary
*.jpeg  binary

# Windows batch files must use CRLF so cmd.exe can execute them
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Files excluded from `git archive` output (release ZIP).
# These are development/repository files — not needed by the game client or Minion.

README.md       export-ignore
CHANGELOG.md    export-ignore
LICENSE         export-ignore
CLAUDE.md       export-ignore
.gitignore      export-ignore
.gitattributes  export-ignore
release.sh      export-ignore
.editorconfig   export-ignore
