root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.lua]
indent_style = space
indent_size = 4

[*.{md,txt}]
# Markdown may use trailing spaces for hard line breaks; .txt is the ESO manifest
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf
